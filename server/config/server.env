# Copy to .env and edit before deploying.
# docker compose uses this file automatically when named .env in the same directory.

MC_VERSION=1.21.1
FABRIC_VERSION=0.16.9
MC_MEMORY=4G
MAX_PLAYERS=20
MOTD=Minetopia
DIFFICULTY=normal
GAMEMODE=survival
ONLINE_MODE=true

# Generate a strong password: openssl rand -hex 16
RCON_PASSWORD=changeme
